{
  "name": "counter",
  "version": "0.1.0",
  "description": "Counter — keyboard-first Electron POS for a Ghanaian beverage distributor.",
  "main": "dist-electron/index.js",
  "type": "module",
  "author": "Naj",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "package:win": "npm run build && electron-builder --win --x64 --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "rebuild-native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "smoke": "node _verify_loyalty.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "node-sqlite3-wasm": "^0.8.57",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.4"
  }
}
